# Application
APP_ENV=local
APP_NAME=DocMind
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# PostgreSQL (replace local-only example values outside development)
POSTGRES_DB=docmind
POSTGRES_USER=docmind
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_PORT_HOST=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PORT_HOST=6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=docmind
MINIO_SECRET_KEY=change-me-too
MINIO_BUCKET=documents
MINIO_SECURE=false
MINIO_PORT_HOST=9000
MINIO_CONSOLE_PORT_HOST=9001

# AI provider contracts (not called in phase one)
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Host ports and browser API URL
BACKEND_PORT_HOST=8000
FRONTEND_PORT_HOST=5173
VITE_API_URL=http://localhost:8000/api/v1

