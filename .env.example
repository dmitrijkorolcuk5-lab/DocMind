# Docker-first local configuration.
# If backend/worker run outside Docker, use localhost for POSTGRES_HOST,
# REDIS_HOST, and MINIO_ENDPOINT instead of postgres/redis/minio.

# Application
APP_ENV=local
APP_NAME=DocMind
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# PostgreSQL
POSTGRES_DB=docmind
POSTGRES_USER=docmind
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PORT_HOST=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0
ARQ_QUEUE_NAME=arq:queue
REDIS_PORT_HOST=6379

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=docmind
MINIO_SECRET_KEY=change-me-too
MINIO_BUCKET=documents
MINIO_SECURE=false
MINIO_PORT_HOST=9000
MINIO_CONSOLE_PORT_HOST=9001

# Gemini AI providers
GEMINI_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
GEMINI_REQUEST_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=3

# Optional OpenAI fallback
OPENAI_API_KEY=

# Upload, indexing, and retrieval
MAX_UPLOAD_SIZE_BYTES=26214400
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
EMBEDDING_BATCH_SIZE=64
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.2
RAG_MAX_CONTEXT_TOKENS=6000
DOCUMENT_PROCESSING_TIMEOUT_SECONDS=300

# Host ports and browser API URL
BACKEND_PORT_HOST=8000
FRONTEND_PORT_HOST=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
